# Fine-grained patterns kept for future variants if a project folder is tracked.
vitis_hls_project/**/solution*/csim/
vitis_hls_project/**/solution*/syn/
vitis_hls_project/**/solution*/sim/
vitis_hls_project/**/solution*/impl/
vitis_hls_project/**/solution*/.autopilot/
