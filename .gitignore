# Local Vitis/Vivado GUI projects and generated files.
# The source of truth is hls/src, hls/tb, hls/scripts, python, docs.
vitis_hls_project/

# Fine-grained patterns kept for future variants if a project folder is tracked.
vitis_hls_project/**/solution*/csim/
vitis_hls_project/**/solution*/syn/
vitis_hls_project/**/solution*/sim/
vitis_hls_project/**/solution*/impl/
vitis_hls_project/**/solution*/.autopilot/
vitis_hls_project/**/.apc/
vitis_hls_project/**/.settings/
vitis_hls_project/**/*.log
vitis_hls_project/**/*.jou
vitis_hls_project/**/*.zip

# Local caches
.Xil/
.cache/
__pycache__/
*.pyc

# Generated data can be recreated
tests/data/*.bin
tests/data/*.csv
